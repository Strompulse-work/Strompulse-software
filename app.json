{
  "expo": {
    "name": "Ibadan Power",
    "slug": "ibadan-power",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F766E"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.ibadanpower.app"
    },
    "android": {
      "package": "com.ibadanpower.app"
    },
    "plugins": [
      "expo-location",
      "expo-notifications",
      "expo-font"
    ],
    "scheme": "ibadanpower"
  }
}
